# Copy this file to a private file on the VM, for example:
#   cp deploy/onebox/env.production.example /opt/citytrip/citytrip.env
# Never commit the filled file.

TZ=Asia/Shanghai
HOST_HTTP_PORT=80
APP_PORT=8081

# Required strong secrets. Generate unique values for every deployment.
MYSQL_ROOT_PASSWORD=CHANGE_ME_GENERATE_32_PLUS_CHARS
APP_DB_NAME=city_trip_db
APP_DB_USERNAME=citytrip
APP_DB_PASSWORD=CHANGE_ME_GENERATE_32_PLUS_CHARS
REDIS_PASSWORD=CHANGE_ME_GENERATE_32_PLUS_CHARS
APP_JWT_SECRET=CHANGE_ME_GENERATE_48_PLUS_CHARS

# Restrict CORS to your real domain/IP after you know it.
# Examples:
#   https://example.com
#   https://example.com,https://www.example.com
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://your-domain.example
APP_DB_VERIFY_ON_STARTUP=true

# Optional first admin bootstrap. Enable only for first boot or password rotation,
# then set APP_BOOTSTRAP_ADMIN_ENABLED=false and redeploy.
APP_BOOTSTRAP_ADMIN_ENABLED=false
APP_BOOTSTRAP_ADMIN_USERNAME=admin
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ADMIN_SYNC_PASSWORD=false

# LLM gateway. Keep OPENAI_API_KEY server-side only; do not put it into frontend VITE_* vars.
LLM_PROVIDER=real
LLM_FALLBACK_TO_MOCK=false
LLM_OPENAI_ENABLED=true
OPENAI_API_KEY=CHANGE_ME_MODEL_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4
OPENAI_CHAT_MODEL=
OPENAI_TEXT_MODEL=
OPENAI_TOOL_MODEL=

# Backend AMap/geo API, server-side.
APP_AMAP_ENABLED=false
APP_AMAP_API_KEY=
APP_AMAP_SECURITY_KEY=
APP_AMAP_SIGN_REQUESTS=false
APP_AMAP_BASE_URL=https://restapi.amap.com
APP_AMAP_DEFAULT_CITY_NAME=成都

# Optional external geo gateway.
APP_GEO_ENABLED=false
APP_GEO_BASE_URL=
APP_GEO_API_KEY=

JAVA_OPTS=-Xms512m -Xmx1024m
