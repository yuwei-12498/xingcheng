<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.citytrip.mapper.UserMapper">

    <select id="selectAdminUserPageRecords" resultType="com.citytrip.model.entity.User">
        select
            id,
            username,
            nickname,
            role,
            status,
            create_time,
            update_time
        from trip_user
        <where>
            <if test="username != null and username != ''">
                username like concat('%', #{username}, '%')
            </if>
        </where>
        order by create_time desc
        limit #{offset}, #{size}
    </select>

    <select id="countAdminUsers" resultType="long">
        select count(1)
        from trip_user
        <where>
            <if test="username != null and username != ''">
                username like concat('%', #{username}, '%')
            </if>
        </where>
    </select>

</mapper>
